# ============================================================
# PyInstaller 打包副产品
# ============================================================

# 构建中间目录
build/

# 打包输出目录（含可执行文件 .exe）
dist/

# PyInstaller spec 文件（自动生成）
*.spec

# ============================================================
# Python 通用
# ============================================================

# 字节码缓存
__pycache__/
*.py[cod]
*$py.class

# 虚拟环境
.venv/
venv/
env/

# 分发/安装产物
*.egg-info/
*.egg
.eggs/

# ============================================================
# 系统文件
# ============================================================

# Windows 缩略图缓存
Thumbs.db
desktop.ini

# macOS
.DS_Store
